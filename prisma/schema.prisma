// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  EMPLOYEE
  HRD
  BOSS
  ADMIN
}

enum AttendanceStatus {
  PRESENT
  LATE
  ALPHA
  FORGOT_CHECKIN
  FORGOT_CHECKOUT
  ON_LEAVE
  HOLIDAY
  TIDAK_ABSEN
}

enum LeaveType {
  ANNUAL_LEAVE
  SICK
  PERSONAL
  HALF_DAY
  OVERTIME
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum OvertimeStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum ShiftSwapStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum RecruitmentStatus {
  WAITING_CALL
  INTERVIEW_1
  INTERVIEW_2
  ACCEPTED
  REJECTED
  CANCELLED
}

enum EmailStatus {
  NOT_SENT
  SENT
  FAILED
  BOUNCED
}

enum BroadcastTag {
  NOTICE
  EVENT
  URGENT
}

enum AttentionFlagType {
  anomaly_checkin
  forgot_checkin
  forgot_checkout
  email_bounce
  overtime_holiday
}

// ============================================================
// CORE MODELS
// ============================================================

model Department {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]
}

model Store {
  id          String   @id @default(cuid())
  name        String
  address     String?
  latitude    Float
  longitude   Float
  radiusMeters Int     @default(150)
  openTime    String   @default("08:00")  // HH:mm WIB
  closeTime   String   @default("21:00") // HH:mm WIB
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users               User[]
  storeAssignments    StoreAssignment[]
  attendances         Attendance[]
  rainyDays           RainyDay[]
}

model Shift {
  id                String   @id @default(cuid())
  name              String
  startTime         String   // HH:mm WIB
  endTime           String   // HH:mm WIB
  checkinWindowMin  Int      @default(30) // minutes before startTime check-in opens
  checkinWindowEndMin Int    @default(240) // minutes after startTime check-in closes
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  usersPrimary      User[]            @relation("PrimaryShift")
  shiftAssignments  ShiftAssignment[]
  shiftOverrides    ShiftOverride[]
  shiftSwapsA       ShiftSwap[]       @relation("ShiftSwapShiftA")
  shiftSwapsB       ShiftSwap[]       @relation("ShiftSwapShiftB")
  broadcastFilters  BroadcastFilterShift[]
}

model User {
  id              String    @id @default(cuid())
  employeeId      String?   @unique
  // SSO-sourced fields (populated on first SSO login)
  ssoId           String?   @unique  // The `id` from the SSO JWT payload
  email           String    @unique
  passwordHash    String?
  name            String
  username        String?   @unique
  avatarUrl       String?
  phoneNumber     String?
  role            Role      @default(EMPLOYEE)
  
  // Synced from SSO (Read-Only in HRIS)
  ssoPositionId   String?
  positionName    String?
  ssoDepartmentId String?
  departmentName  String?

  // HRIS Settings
  joinDate        DateTime @default(now())
  weeklyOffDays   Int[]    @default([0]) // Array of days (0=Sun, 1=Mon... 6=Sat)
  
  isActive        Boolean   @default(true)
  notifEnabled    Boolean   @default(true)
  twoFAEnabled    Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Current assignments (denormalized for quick lookup)
  departmentId    String?
  storeId         String?
  shiftId         String?

  shiftCycle      String[]    // Array of Shift IDs for N-week rotation
  cycleStartDate  DateTime?   // Anchor date (Monday) where index 0 starts
  halfDays        Int[]       @default([]) // e.g. [6] for Saturday
  leaveQuotaRemaining Int     @default(12) // Sisa Cuti
  lastQuotaResetDate  DateTime? // Tanggal terakhir quota direset (anniversary)

  department      Department?         @relation(fields: [departmentId], references: [id])
  store           Store?              @relation(fields: [storeId], references: [id])
  shift           Shift?              @relation("PrimaryShift", fields: [shiftId], references: [id])

  attendances         Attendance[]
  leaveRequests       LeaveRequest[]
  overtimeRequests    OvertimeRequest[]
  leaveQuotas         LeaveQuota[]
  pushSubscriptions   PushSubscription[]
  appNotifications    AppNotification[]
  storeAssignments    StoreAssignment[]
  shiftAssignments    ShiftAssignment[]
  shiftOverrides      ShiftOverride[]
  shiftSwapsA         ShiftSwap[]       @relation("ShiftSwapUserA")
  shiftSwapsB         ShiftSwap[]       @relation("ShiftSwapUserB")
  shiftSwapsApproved  ShiftSwap[]       @relation("ShiftSwapApprover")
  attentionFlags      AttentionFlag[]
  performanceMonthly  PerformanceMonthly[]
  recruitmentCreated  Recruitment[]
  broadcastsCreated   Broadcast[]
  broadcastFilters    BroadcastFilterUser[]
  userDevices         UserDevice[]
  payrollConfig       UserPayrollConfig?
  payrollSlips        PayrollSlip[]
}

model UserDevice {
  id         String   @id @default(cuid())
  userId     String
  deviceId   String
  userAgent  String?
  lastUsedAt DateTime @default(now())
  isBlocked  Boolean  @default(false)

  user       User     @relation(fields: [userId], references: [id])

  @@unique([userId, deviceId])
}

// ============================================================
// ATTENDANCE
// ============================================================

model Attendance {
  id               String           @id @default(cuid())
  userId           String
  storeId          String?
  date             DateTime         // Midnight UTC for the WIB calendar day
  status           AttendanceStatus @default(PRESENT)
  checkInTime      DateTime?
  checkOutTime     DateTime?
  checkInPhotoUrl  String?
  checkOutPhotoUrl String?
  checkInLat       Float?
  checkInLng       Float?
  checkOutLat      Float?
  checkOutLng      Float?
  checkInDistance  Float?           // Distance in meters from store at check-in
  checkOutDistance Float?
  lateMinutes      Int              @default(0)
  isAnomaly        Boolean          @default(false)
  anomalyNote      String?
  isForgotCheckin  Boolean          @default(false)
  isForgotCheckout Boolean          @default(false)
  isRainyDay       Boolean          @default(false)
  photoTimestamp   DateTime?
  locationTimestamp DateTime?
  isOverridden     Boolean          @default(false)
  overrideReason   String?
  overriddenById   String?
  penaltyAmount    Int              @default(0)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  user          User           @relation(fields: [userId], references: [id])
  store         Store?         @relation(fields: [storeId], references: [id])
  attentionFlags AttentionFlag[]

  @@unique([userId, date])
}

model ShiftOverride {
  id          String   @id @default(cuid())
  userId      String
  shiftId     String
  date        DateTime // Midnight UTC for the specific WIB day
  customStart String?  // HH:mm override (optional)
  customEnd   String?  // HH:mm override (optional)
  reason      String?
  createdAt   DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  shift Shift @relation(fields: [shiftId], references: [id])

  @@unique([userId, date])
}

model ShiftSwap {
  id          String          @id @default(cuid())
  userAId     String
  userBId     String
  shiftAId    String          // userA's original shift
  shiftBId    String          // userB's original shift
  swapDate    DateTime        // The calendar day of the swap
  status      ShiftSwapStatus @default(PENDING)
  approvedById String?
  rejectReason String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  userA       User  @relation("ShiftSwapUserA", fields: [userAId], references: [id])
  userB       User  @relation("ShiftSwapUserB", fields: [userBId], references: [id])
  shiftA      Shift @relation("ShiftSwapShiftA", fields: [shiftAId], references: [id])
  shiftB      Shift @relation("ShiftSwapShiftB", fields: [shiftBId], references: [id])
  approvedBy  User? @relation("ShiftSwapApprover", fields: [approvedById], references: [id])
}

// ============================================================
// LEAVE & OVERTIME
// ============================================================

model LeaveQuota {
  id              String   @id @default(cuid())
  userId          String
  periodStart     DateTime // Anniversary date
  periodEnd       DateTime
  totalDays       Int      @default(12)
  usedDays        Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, periodStart])
}

model LeaveRequest {
  id            String      @id @default(cuid())
  userId        String
  type          LeaveType
  status        LeaveStatus @default(PENDING)
  startDate     DateTime
  endDate       DateTime
  totalDays     Float       @default(1)
  reason        String?
  sickNoteUrl   String?
  sickNoteFileName String?
  rejectReason  String?
  // For HALF_DAY type
  halfDayType   String?     // 'LATE_IN' or 'EARLY_OUT'
  halfDayTime   String?     // e.g. '13:00'
  unpaidHours   Int?        @default(0) // Rounded integer of unpaid hours for payroll
  // For SICK type (2-step verification)
  isPaid        Boolean     @default(true)
  // For OVERTIME type
  overtimeStart DateTime?
  overtimeEnd   DateTime?
  overtimeTask  String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model OvertimeRequest {
  id           String         @id @default(cuid())
  userId       String
  status       OvertimeStatus @default(PENDING)
  overtimeDate DateTime
  startTime    DateTime
  endTime      DateTime?
  totalHours   Float?
  task         String?
  rejectReason String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id])
}

// ============================================================
// CALENDAR
// ============================================================

model CalendarEvent {
  id         String   @id @default(cuid())
  date       DateTime // Midnight UTC for the WIB calendar day
  title      String
  type       String   // e.g. "event", "holiday", "rainy", "urgent"
  scope      String   // e.g. "all", "department", "shift", "store", "individual"
  scopeValue String?  // Stores the target, e.g. "IT", "Morning Shift", "User Name"
  note       String?
  createdAt  DateTime @default(now())
}

model HolidayMarker {
  id          String   @id @default(cuid())
  date        DateTime @unique
  name        String
  createdAt   DateTime @default(now())

  assignments HolidayAssignment[]
}

model HolidayAssignment {
  id              String        @id @default(cuid())
  holidayMarkerId String
  applyToAll      Boolean       @default(true)
  userId          String?

  holidayMarker HolidayMarker @relation(fields: [holidayMarkerId], references: [id], onDelete: Cascade)
}

model RainyDay {
  id        String   @id @default(cuid())
  date      DateTime
  storeId   String?  // null = all stores
  createdAt DateTime @default(now())

  store Store? @relation(fields: [storeId], references: [id])

  @@unique([date, storeId])
}

// ============================================================
// PERFORMANCE
// ============================================================

model PerformanceMonthly {
  id                String   @id @default(cuid())
  userId            String
  year              Int
  month             Int      // 1-12
  totalPresent      Int      @default(0)
  totalLate         Int      @default(0)
  totalAlpha        Int      @default(0)
  totalLeave        Int      @default(0)
  totalSick         Int      @default(0)
  totalAnnualLeave  Int      @default(0)
  totalOvertime     Float    @default(0)
  lateMinutesTotal  Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, year, month])
}

// ============================================================
// RECRUITMENT
// ============================================================

model Recruitment {
  id              String            @id @default(cuid())
  name            String
  email           String
  phone           String?
  position        String
  status          RecruitmentStatus @default(WAITING_CALL)
  cvUrl           String?
  cvFileName      String?
  notes           String?
  interviewDate   DateTime?
  interview2Date  DateTime?
  rejectionReason String?
  cancelReason    String?

  callEmailStatus      EmailStatus @default(NOT_SENT)
  callEmailSentAt      DateTime?
  rejectEmailStatus    EmailStatus @default(NOT_SENT)
  rejectEmailSentAt    DateTime?
  rescheduleEmailStatus EmailStatus @default(NOT_SENT)
  rescheduleEmailSentAt DateTime?
  acceptEmailStatus    EmailStatus @default(NOT_SENT)
  acceptEmailSentAt    DateTime?
  lastEmailError       String?

  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User @relation(fields: [createdById], references: [id])
}

// ============================================================
// IN-APP NOTIFICATIONS
// ============================================================
model AppNotification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  url       String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
}

// ============================================================
// WEB PUSH SUBSCRIPTIONS
// ============================================================

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Broadcast {
  id          String       @id @default(cuid())
  title       String
  message     String
  tag         BroadcastTag
  scheduledAt DateTime?    // When HRD wants to send it (null = send immediately)
  sentAt      DateTime?    // Actual delivery timestamp (null = not yet sent)
  isSent      Boolean      @default(false)
  createdById String
  createdAt   DateTime     @default(now())

  createdBy     User                   @relation(fields: [createdById], references: [id])
  filterDepts   BroadcastFilterDept[]
  filterStores  BroadcastFilterStore[]
  filterShifts  BroadcastFilterShift[]
  filterUsers   BroadcastFilterUser[]
}

model BroadcastFilterDept {
  id           String @id @default(cuid())
  broadcastId  String
  departmentId String

  broadcast Broadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
}

model BroadcastFilterStore {
  id          String @id @default(cuid())
  broadcastId String
  storeId     String

  broadcast Broadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
}

model BroadcastFilterShift {
  id          String @id @default(cuid())
  broadcastId String
  shiftId     String

  broadcast Broadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  shift     Shift     @relation(fields: [shiftId], references: [id])
}

model BroadcastFilterUser {
  id          String @id @default(cuid())
  broadcastId String
  userId      String

  broadcast Broadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id])
}

// ============================================================
// ATTENTION FLAGS
// ============================================================

model AttentionFlag {
  id           String            @id @default(cuid())
  userId       String            // The affected employee
  type         AttentionFlagType
  description  String
  relatedId    String?           // ID of related attendance, recruitment, etc.
  isResolved   Boolean           @default(false)
  resolvedNote String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  user       User        @relation(fields: [userId], references: [id])
  attendance Attendance? @relation(fields: [relatedId], references: [id])
}

// ============================================================
// ASSIGNMENT HISTORY (audit trail)
// ============================================================

model StoreAssignment {
  id        String    @id @default(cuid())
  userId    String
  storeId   String
  startDate DateTime
  endDate   DateTime?
  createdAt DateTime  @default(now())

  user  User  @relation(fields: [userId], references: [id])
  store Store @relation(fields: [storeId], references: [id])
}

model ShiftAssignment {
  id        String    @id @default(cuid())
  userId    String
  shiftId   String
  startDate DateTime
  endDate   DateTime?
  createdAt DateTime  @default(now())

  user  User  @relation(fields: [userId], references: [id])
  shift Shift @relation(fields: [shiftId], references: [id])
}

// ============================================================
// PAYROLL
// ============================================================

/// Per-employee salary configuration. Carries forward to new periods.
/// When boss changes this, old PayrollSlips remain untouched.
model UserPayrollConfig {
  id               String   @id @default(cuid())
  userId           String   @unique
  baseSalary26Days Int      @default(0)  // Total target salary for a standard 26-day month
  uangMakan        Int      @default(0)  // Meal allowance
  transport        Int      @default(0)  // Transport allowance
  bpjs             Int      @default(0)  // BPJS deduction
  pph21            Int      @default(0)  // Tax deduction
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// Frozen payroll snapshot for a specific 26th–25th period.
/// Regenerating replaces the record; old periods remain intact.
model PayrollSlip {
  id              String   @id @default(cuid())
  slug            String?  @unique // Clean URL slug: e.g. hns-0001-jun-2026
  userId          String
  periodStart     DateTime // Always the 26th of the previous month (UTC midnight)
  periodEnd       DateTime // Always the 25th of the current month (UTC midnight)

  // ── Snapshot of config at generation time ──────────────────────
  baseSalary26Days Int
  uangMakan        Int     @default(0)
  transport        Int     @default(0)
  bpjs             Int     @default(0)
  pph21            Int     @default(0)

  // ── Calculated working day info ────────────────────────────────
  scheduledWorkDays  Int   // How many working days fell in this period (25/26/27)
  dailyRate          Int   // baseSalary26Days / 26 (stored as snapshot)
  hourlyRate         Int   // dailyRate / shift hours

  // ── Pendapatan (Earnings) ──────────────────────────────────────
  gajiPokok          Int   // baseSalary (adjusted for working days) - uangMakan - transport
  lembur             Int   @default(0) // Approved overtime pay
  totalPendapatan    Int   // gajiPokok + uangMakan + transport + lembur

  // ── Potongan (Deductions) ─────────────────────────────────────
  potonganIzin       Int   @default(0) // Unpaid leave days * daily rate
  potonganTerlambat  Int   @default(0) // Count of late/forgot * 20,000
  potonganLainnya    Int   @default(0) // Other custom deductions (e.g. BPJS, PPh21 already in bpjs/pph21)
  totalPotongan      Int   // bpjs + pph21 + potonganIzin + potonganTerlambat

  // ── Net ───────────────────────────────────────────────────────
  totalPenerimaan    Int   // totalPendapatan - totalPotongan

  // ── Attendance Summary (for payslip display) ──────────────────
  kehadiran          Int   @default(0)
  ketidakhadiran     Int   @default(0)
  cuti               Int   @default(0)
  izin               Int   @default(0)
  sakit              Int   @default(0)
  terlambat          Int   @default(0)
  lupaAbsen          Int   @default(0)
  izinSetengahHari   Int   @default(0)

  // ── Notes ─────────────────────────────────────────────────────
  notes              String?
  isPublished        Boolean  @default(false) // true = visible to employee in Profile
  generatedAt        DateTime @default(now())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, periodStart])
}
